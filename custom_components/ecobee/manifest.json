{
  "domain": "ecobee",
  "name": "ecobee",
  "codeowners": ["@shaelr"],
  "config_flow": true,
  "documentation": "https://www.home-assistant.io/integrations/ecobee",
  "homekit": {
    "models": ["EB", "ecobee*"]
  },
  "integration_type": "hub",
  "iot_class": "cloud_polling",
  "loggers": ["pyecobee"],
  "requirements": [
    "python-ecobee-api @ git+https://github.com/shaelr/python-ecobee-api.git@v0.7.0"
  ],
  "single_config_entry": true,
  "version": "0.7.0",
  "zeroconf": [
    {
      "type": "_ecobee._tcp.local."
    },
    {
      "properties": {
        "mdl": "eb-*"
      },
      "type": "_sideplay._tcp.local."
    },
    {
      "properties": {
        "mdl": "ecobee*"
      },
      "type": "_sideplay._tcp.local."
    }
  ]
}
